# ⚠️ NO commitear este archivo con valores reales.
# Copia este archivo como secret.yaml y rellena el token en base64:
#   echo -n "TU_TOKEN" | base64
apiVersion: v1
kind: Secret
metadata:
  name: chess-tournament-bot-secret
  namespace: chess-tournament
  labels:
    app: chess-tournament-bot
type: Opaque
data:
  TELEGRAM_BOT_TOKEN: "REEMPLAZAR_CON_BASE64_DEL_TOKEN"
